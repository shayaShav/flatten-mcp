{
    "name": "flatten-mcp",
    "version": "2.0.5",
    "mcpName": "io.github.shayaShav/flatten-mcp",
    "description": "Cut a Claude Code session's context tokens losslessly: bulky tool output moves to a local backup, every prompt stays verbatim, and the session resumes lighter — the reversible alternative to /compact. Ships a terminal CLI and an in-memory library for raw Messages API conversations.",
    "type": "module",
    "main": "dist/lib.js",
    "types": "dist/lib.d.ts",
    "exports": {
        ".": {
            "types": "./dist/lib.d.ts",
            "import": "./dist/lib.js"
        }
    },
    "bin": {
        "flatten-mcp": "dist/index.js",
        "flatten-mcp-cli": "dist/cli.js",
        "flatten-mcp-session": "dist/session-cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsc --watch",
        "prepare": "tsc",
        "prepublishOnly": "rm -rf dist && tsc",
        "test": "vitest run"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "claude",
        "claude-code",
        "context-window",
        "tokens",
        "session",
        "history",
        "flatten",
        "compaction"
    ],
    "author": "Shaya Shaviv",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/shayaShav/flatten-mcp.git"
    },
    "homepage": "https://github.com/shayaShav/flatten-mcp#readme",
    "bugs": {
        "url": "https://github.com/shayaShav/flatten-mcp/issues"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^20.17.0",
        "typescript": "^5.7.2",
        "vitest": "^3.0.0"
    }
}
