{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.shayaShav/flatten-mcp",
    "description": "Flatten Claude Code sessions: keep every prompt and event verbatim, resume at a lower token count.",
    "repository": {
        "url": "https://github.com/shayaShav/flatten-mcp",
        "source": "github",
        "id": "1266659149"
    },
    "version": "1.0.1",
    "websiteUrl": "https://github.com/shayaShav/flatten-mcp#readme",
    "icons": [
        {
            "src": "https://raw.githubusercontent.com/shayaShav/flatten-mcp/main/assets/logo.png",
            "mimeType": "image/png",
            "sizes": [
                "1536x1536"
            ]
        }
    ],
    "packages": [
        {
            "registryType": "npm",
            "registryBaseUrl": "https://registry.npmjs.org",
            "identifier": "flatten-mcp",
            "version": "1.0.1",
            "transport": {
                "type": "stdio"
            },
            "environmentVariables": [
                {
                    "name": "ANTHROPIC_API_KEY",
                    "description": "Optional. If set, token savings are counted exactly via Anthropic's count_tokens endpoint instead of estimated locally.",
                    "isRequired": false,
                    "isSecret": true,
                    "format": "string"
                },
                {
                    "name": "FLATTEN_COUNT_MODEL",
                    "description": "Optional. Model id used for the exact token count (default: claude-haiku-4-5-20251001).",
                    "isRequired": false,
                    "format": "string"
                }
            ]
        }
    ]
}
